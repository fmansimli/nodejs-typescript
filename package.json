{
  "name": "nodejs-typescript",
  "version": "1.0.0",
  "description": "NodeJS (expressjs) starter template with typescript",
  "main": "src/server.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "start": "npm run build && node lib/server.js",
    "build": "npm run build:types && npm run build:js",
    "clear:win": "rimraf lib",
    "clear:linux": "rm -rf lib",
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch",
    "build:types": "tsc --emitDeclarationOnly",
    "build:js": "babel src --out-dir lib --extensions \".ts,.tsx\" --source-maps inline"
  },
  "dependencies": {
    "express": "^4.17.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.14.5",
    "@babel/core": "^7.14.6",
    "@babel/node": "^7.14.7",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.15.0",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.14.7",
    "@babel/preset-typescript": "^7.8.3",
    "@babel/register": "^7.15.3",
    "@babel/runtime": "^7.14.8",
    "@types/express": "^4.17.13",
    "nodemon": "^2.0.12",
    "rimraf": "^3.0.2",
    "ts-node": "^10.2.1",
    "typescript": "^3.7.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmansimli/nodejs-typescript.git"
  },
  "keywords": [],
  "author": "Farid Mansimli <farid.mansimli@faridmansim.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/fmansimli/nodejs-typescript/issues"
  },
  "homepage": "https://github.com/fmansimli/nodejs-typescript#readme"
}
